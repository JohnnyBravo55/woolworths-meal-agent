# Copy to .env and fill in as needed
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Local dev: unlock premium chefs without a subscriber account (1 = on)
MEAL_AGENT_DEV_PREMIUM=1

# Hosted tester deploy (Render) — leave unset locally for no access gate
# MEAL_AGENT_ACCESS_CODE=usertest1
# MEAL_AGENT_CORS_ORIGINS=https://YOUR_USER.github.io
# MEAL_AGENT_COOKIE_SECURE=1
